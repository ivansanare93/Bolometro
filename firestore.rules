rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Permitir consultas a la colección de usuarios para búsqueda por email
      // Solo queries limitadas (list) para búsquedas de 1 resultado
      allow list: if request.auth != null && 
                     request.query.limit <= 1;
      
      // El usuario puede leer su propio perfil completo
      // Otros usuarios autenticados pueden leer perfiles para buscar amigos
      allow get: if request.auth != null;
      // Solo el usuario puede escribir su propio perfil
      // Esto incluye actualizar el FCM token
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Reglas para la subcolección de sesiones
      match /sesiones/{sesionId} {
        // El propietario puede leer, escribir y eliminar sus sesiones
        // Los amigos pueden leer sesiones para comparar rankings
        allow read: if request.auth != null && 
                    (request.auth.uid == userId || 
                     exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid)));
        allow write: if request.auth != null && request.auth.uid == userId;
        
        // Validaciones adicionales para escritura
        allow create: if request.auth != null 
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasAll(['fecha', 'lugar', 'tipo', 'partidas'])
                      && request.resource.data.tipo in ['Entrenamiento', 'Competición'];
        
        allow update: if request.auth != null 
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasAll(['fecha', 'lugar', 'tipo', 'partidas'])
                      && request.resource.data.tipo in ['Entrenamiento', 'Competición'];
      }
      
      // Reglas para la subcolección de amigos
      match /friends/{friendId} {
        // El usuario puede leer su lista de amigos
        allow read: if request.auth != null && request.auth.uid == userId;
        // Solo el usuario puede modificar su lista de amigos
        allow write: if request.auth != null && request.auth.uid == userId;
        // Permitir agregar un amigo cuando se acepta una solicitud de amistad:
        // El usuario que acepta (request.auth.uid = friendId) puede escribir 
        // en la colección de amigos del remitente (userId) si el documento 
        // que está creando corresponde al usuario autenticado
        allow create: if request.auth != null && 
                      request.auth.uid == friendId &&
                      request.resource.data.userId == request.auth.uid;
        // Permitir eliminar un amigo de forma bidireccional:
        // Un usuario puede eliminar su propia entrada (donde su userId está 
        // almacenado en el documento) de la colección de amigos de otro usuario
        allow delete: if request.auth != null && 
                      request.auth.uid == friendId &&
                      resource.data.userId == request.auth.uid;
      }
      
      // Reglas para la subcolección de solicitudes de amistad
      match /friendRequests/{requestId} {
        // El remitente o el destinatario pueden leer la solicitud
        allow read: if request.auth != null && 
                    (request.auth.uid == userId || 
                     request.auth.uid == resource.data.fromUserId);
        // Solo el remitente puede crear una solicitud
        allow create: if request.auth != null && 
                      request.auth.uid == request.resource.data.fromUserId &&
                      request.resource.data.toUserId == userId;
        // Solo el destinatario puede actualizar una solicitud (aceptar/rechazar)
        allow update: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.data.toUserId == userId;
        // El remitente o destinatario pueden eliminar la solicitud
        allow delete: if request.auth != null && 
                      (request.auth.uid == userId || 
                       request.auth.uid == resource.data.fromUserId);
      }
      
      // Reglas para la subcolección de notificaciones
      match /notifications/{notificationId} {
        // Solo el propietario puede leer sus notificaciones
        allow read: if request.auth != null && request.auth.uid == userId;
        // Solo el propietario puede actualizar (marcar como leída) sus notificaciones
        allow update: if request.auth != null && request.auth.uid == userId;
        // Permitir crear notificaciones desde otros usuarios (solicitudes de amistad)
        allow create: if request.auth != null &&
                      request.resource.data.type in ['friend_request', 'friend_request_accepted'];
        // Solo el propietario puede eliminar sus notificaciones
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Reglas para la subcolección de gamificación
      match /gamification/{document=**} {
        // Solo el propietario puede leer y escribir sus datos de gamificación
        // Esto incluye el documento 'progress' y la subcolección 'achievements'
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Denegar acceso a cualquier otra ruta
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
